AGENTIVA_MODE=shadow
AGENTIVA_POLICY_PATH=policies/default.yaml
AGENTIVA_RATE_LIMIT_PER_MINUTE=100
AGENTIVA_DATABASE_URL=sqlite+aiosqlite:///./agentiva.db
AGENTIVA_HOST=0.0.0.0
AGENTIVA_PORT=8000

# Optional: use PostgreSQL instead of SQLite
# AGENTIVA_DATABASE_URL=postgresql://agentiva:agentiva@postgres:5432/agentiva

POSTGRES_DB=agentiva
POSTGRES_USER=agentiva
POSTGRES_PASSWORD=agentiva

REDIS_URL=redis://redis:6379/0
NEXT_PUBLIC_API_BASE=http://localhost:8000
PYTHONUNBUFFERED=1

# Optional: enables AI-powered chat (Claude) in the dashboard
OPENROUTER_API_KEY=your-key-here  # Get from openrouter.ai/keys
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet  # optional override
